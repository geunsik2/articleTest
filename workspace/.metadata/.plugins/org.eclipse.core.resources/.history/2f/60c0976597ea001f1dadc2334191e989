package egovframework.example.main.service;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import egovframework.example.main.dao.MainDao;
import egovframework.example.main.vo.MainVo;

//@Service: 이 클래스가 비즈니스 로직을 처리하는 서비스 계층의 컴포넌트임을 나타냄
@Service
public class MainServiceImpl implements MainService {
	
	// @Autowired: MainDao 빈을 자동으로 주입받음
    @Autowired
    private MainDao mainDao;
    
    // 게시글 목록 조회
    @Override
    public List<MainVo> selectMain(MainVo mainVo) throws Exception {
        // MainDao를 통해 테스트 목록을 조회하고 반환
        return testDao.selectMain(mainVo);
    }
 
    // 새 테스트 등록
    @Override
    public void insertMain(MainVo mainVo) throws Exception {
        // MainDao를 통해 새로운 테스트 정보를 데이터베이스에 삽입
        testDao.insertMain(mainVo);
    }
 
    // 특정 테스트 상세 정보 조회
    @Override
    public MainVo selectDetail(int testId) throws Exception {
        // MainDao를 통해 특정 ID의 테스트 상세 정보를 조회하고 반환
        return testDao.selectDetail(testId);
    }
 
    // 테스트 정보 업데이트
    @Override
    public void updateMain(MainVo mainVo) throws Exception {
        // MainDao를 통해 테스트 정보를 업데이트
        testDao.updateMain(mainVo);
    }
 
    // 테스트 삭제
    @Override
    public void deleteMain(int testId) throws Exception {
        // MainDao를 통해 특정 ID의 테스트를 삭제
        testDao.deleteMain(testId);
    }
	
}
