<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>게시글 상세</title>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <style>
        .container {
            width: 80%;
            margin: 0 auto;
            padding: 20px;
        }
        .form-group {
            margin-bottom: 15px;
        }
        .form-group label {
            display: inline-block;
            width: 100px;
        }
        .btn-group {
            margin-top: 20px;
        }
        button {
            padding: 8px 16px;
            margin-right: 10px;
        }
        textarea {
            width: 100%;
            height: 200px;
        }
        input[type=text] {
            width: 100%;
            padding: 8px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>게시글 상세</h1>
        
        <div id="boardDetail">
            <!-- 게시글 상세 정보가 여기에 AJAX로 로드됩니다 -->
        </div>
        
        <div class="btn-group">
            <button type="button" id="updateBtn">수정</button>
            <button type="button" id="deleteBtn">삭제</button>
            <button type="button" id="listBtn">목록</button>
        </div>
    </div>
    
    <script>
        $(document).ready(function() {
            // URL에서 testId 파라미터 가져오기
            var testId = getUrlParameter('testId');
            
            // 게시글 상세 정보 로드
            loadBoardDetail(testId);
            
            // 수정 버튼 클릭 이벤트
            $('#updateBtn').on('click', function() {
                // 수정 폼 보여주기
                var testId = $(this).data('testId');
                var title = $('#title').val();
                var content = $('#content').val();
                var writer = $('#writer').val();
                
                $('#boardDetail').html(`
                    <form id="updateForm" enctype="multipart/form-data">
                        <input type="hidden" name="testId" id="updateTestId" value="${testId}">
                        <div class="form-group">
                            <label for="updateTitle">제목</label>
                            <input type="text" name="title" id="updateTitle" value="${title}" required>
                        </div>
                        <div class="form-group">
                            <label for="updateWriter">작성자</label>
                            <input type="text" name="writer" id="updateWriter" value="${writer}" required>
                        </div>
                        <div class="form-group">
                            <label for="updateContent">내용</label>
                            <textarea name="content" id="updateContent" required>${content}</textarea>
                        </div>
                        <div class="form-group">
                            <label for="uploadFile">파일</label>
                            <input type="file" name="uploadFile" id="uploadFile">
                        </div>
                        <div class="btn-group">
                            <button type="button" id="submitUpdateBtn">저장</button>
                            <button type="button" id="cancelUpdateBtn">취소</button>
                        </div>
                    </form>
                `);
                
                // 수정 제출 버튼 이벤트
                $('#submitUpdateBtn').on('click', function() {
                    updateBoard();
                });
                
                // 취소 버튼 이벤트
                $('#cancelUpdateBtn').on('click', function() {
                    loadBoardDetail(testId);
                });
            });
            
            // 삭제 버튼 클릭 이벤트
            $('#deleteBtn').on('click', function() {
                if (confirm('정말로 삭제하시겠습니까?')) {
                    deleteBoard(testId);
                }
            });
            
            // 목록 버튼 클릭 이벤트
            $('#listBtn').on('click', function() {
                window.location.href = "main.do";
            });
        });
        
        // URL 파라미터 가져오기 함수
        function getUrlParameter(name) {
            name = name.replace(/[\[]/, '\\[').replace(/[\]]/, '\\]');
            var regex = new RegExp('[\\?&]' + name + '=([^&#]*)');
            var results = regex.exec(location.search);
            return results === null ? '' : decodeURIComponent(results[1].replace(/\+/g, ' '));
        }
        
        // 게시글 상세 정보 로드 함수
        function loadBoardDetail(testId) {
            $.ajax({
                type: "POST",
                url: "getMainDetail.do",
                data: { testId: testId },
                dataType: "json",
                success: function(response) {
                    var board = response.vo;
                    renderBoardDetail(board);
                    
                    // 수정 버튼에 게시글 ID 데이터 설정
                    $('#updateBtn').data('testId', board.testId);
                },
                error: function(xhr, status, error) {
                    console.error("Error loading board detail: " + error);
                    alert("게시글 상세 정보를 불러오는 중 오류가 발생했습니다.");
                }
            });
        }
        
        // 게시글 상세 정보 렌더링 함수
        function renderBoardDetail(board) {
            var fileDownloadHtml = '';
            if (board.fileName) {
                fileDownloadHtml = `
                    <div class="form-group">
                        <label>첨부파일</label>
                        <a href="fileDownload.do?fileName=${board.fileName}">${board.fileName}</a>
                    </div>
                `;
            }
            
            var detailHtml = `
                <div class="form-group">
                    <label>제목</label>
                    <input type="text" id="title" value="${board.title}" readonly>
                </div>
                <div class="form-group">
                    <label>작성자</label>
                    <input type="text" id="writer" value="${board.writer}" readonly>
                </div>
                <div class="form-group">
                    <label>등록일</label>
                    <input type="text" value="${formatDate(board.regDate)}" readonly>
                </div>
                <div class="form-group">
                    <label>조회수</label>
                    <input type="text" value="${board.viewCnt || 0}" readonly>
                </div>
                <div class="form-group">
                    <label>내용</label>
                    <textarea id="content" readonly>${board.content}</textarea>
                </div>
                ${fileDownloadHtml}
            `;
            
            $('#boardDetail').html(detailHtml);
        }
        
        // 게시글 수정 함수
        function updateBoard() {
            var formData = new FormData($("#updateForm")[0]);
            
            $.ajax({
                type: "POST",
                url: "updateMain.do",
                data: formData,
                processData: false,
                contentType: false,
                success: function(response) {
                    if (response.success) {
                        alert(response.message);
                        loadBoardDetail(response.testId);
                    } else {
                        alert(response.message);
                    }
                },
                error: function(xhr, status, error) {
                    console.error("Error updating board: " + error);
                    alert("게시글 수정 중 오류가 발생했습니다.");
                }
            });
        }
        
        // 게시글 삭제 함수
        function deleteBoard(testId) {
            $.ajax({
                type: "POST",
                url: "deleteMain.do",
                data: { testId: testId },
                dataType: "json",
                success: function(response) {
                    if (response.success) {
                        alert(response.message);
                        window.location.href = "main.do";
                    } else {
                        alert(response.message);
                    }
                },
                error: function(xhr, status, error) {
                    console.error("Error deleting board: " + error);
                    alert("게시글 삭제 중 오류가 발생했습니다.");
                }
            });
        }
        
        // 날짜 포맷 함수
        function formatDate(dateString) {
            if (!dateString) return '';
            var date = new Date(dateString);
            var year = date.getFullYear();
            var month = String(date.getMonth() + 1).padStart(2, '0');
            var day = String(date.getDate()).padStart(2, '0');
            return year + '-' + month + '-' + day;
        }
    </script>
</body>
</html>
